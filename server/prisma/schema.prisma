generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  password              String
  name                  String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  projects              Project[]
  apiKeys               ApiKey[]
  aiConfigs             AIConfig[]
  consistencyCheckRules ConsistencyCheckRule[]
  customWritingStyles   CustomWritingStyle[]
  writingStyleFusions   WritingStyleFusion[]
  writingStyleHistory   WritingStyleHistory[]
  logRetentionSetting LogRetentionSetting?
}

model AIConfig {
  id        String   @id @default(uuid())
  userId    String
  action    String
  provider  String
  model     String?
  apiKeyId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@unique([userId, action])
}

model Project {
  id                      String                   @id @default(uuid())
  userId                  String
  title                   String
  subtitle                String?
  synopsis                String
  genre                   String
  tags                    String
  status                  String                   @default("IDEATION")
  wordCount               Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  worldSettings           WorldSetting[]
  characters              Character[]
  scenes                  Scene[]
  plots                   Plot[]
  chapters                Chapter[]
  consistencyCheckReports ConsistencyCheckReport[]
  writingStyleHistory     WritingStyleHistory[]
  loreEntries             LoreEntry[]
  chekhovsGuns            ChekhovsGun[]
  outlines                Outline[]
  turningPoints           TurningPoint[]
  timelineEvents          TimelineEvent[]
  dialogueSessions        DialogueSession[]
  dialogueQualityReports  DialogueQualityReport[]
  storyContracts          StoryContract[]
  storyContextPacks       StoryContextPack[]
  storyAgentRuns          StoryAgentRun[]
  chapterCommits          ChapterCommit[]
  reviewReports           ReviewReport[]
  repairPlans             RepairPlan[]
  storyEvents             StoryEvent[]
  characterStates         CharacterState[]
  worldStateFacts         WorldStateFact[]
  openLoops               OpenLoop[]
  storyEntities           StoryEntity[]
  storyRelations          StoryRelation[]
  publishingAssets        PublishingAsset[]
  storyVectorIndexes      StoryVectorIndex[]
  projectionJobs          ProjectionJob[]
  storyAiJobs             StoryAiJob[]
  projectAiSuggestionJobs ProjectAiSuggestionJob[]
  projectStoryAiJobs      ProjectStoryAiJob[]
  outlineAiJobs           OutlineAiJob[]
  conversations           Conversation[]

  // 写作风格配置
  currentWritingStyleId String?
  writingStyleConfig    String?
  webNovelTemplateId    String?
  chapterTemplateId     String?
}

model PublishingAsset {
  id            String   @id @default(uuid())
  projectId     String
  synopsis      String
  sellingPoints String
  coverPrompt   String
  coverSvg      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model StoryVectorIndex {
  id            String   @id @default(uuid())
  projectId     String
  sourceType    String
  sourceId      String
  text          String
  embeddingJson String
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sourceType, sourceId])
  @@index([projectId])
  @@index([sourceType])
}

model ProjectionJob {
  id         String   @id @default(uuid())
  projectId  String
  scope      String
  status     String   @default("PENDING")
  totalItems Int      @default(0)
  doneItems  Int      @default(0)
  failedItems Int     @default(0)
  error      String?
  items      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model WorldSetting {
  id          String             @id @default(uuid())
  projectId   String
  category    String
  name        String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       WorldSettingItem[]

  @@unique([projectId, category, name])
}

model WorldSettingItem {
  id             String       @id @default(uuid())
  worldSettingId String
  name           String
  description    String?
  details        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  worldSetting   WorldSetting @relation(fields: [worldSettingId], references: [id], onDelete: Cascade)
}

model Character {
  id                String                  @id @default(uuid())
  projectId         String
  name              String
  role              String?
  appearance        String?
  personality       String?
  background        String?
  goals             String?
  flaws             String?
  arc               String?
  voice             String?
  notes             String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  relationshipsFrom CharacterRelationship[] @relation("CharacterFrom")
  relationshipsTo   CharacterRelationship[] @relation("CharacterTo")
  appearances       CharacterAppearance[]
}

model CharacterRelationship {
  id            String    @id @default(uuid())
  fromId        String
  toId          String
  relationship  String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fromCharacter Character @relation("CharacterFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toCharacter   Character @relation("CharacterTo", fields: [toId], references: [id], onDelete: Cascade)
}

model Scene {
  id         String   @id @default(uuid())
  projectId  String
  title      String
  summary    String?
  location   String?
  timePeriod String?
  characters String
  content    String?
  order      Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Plot {
  id          String      @id @default(uuid())
  projectId   String
  title       String
  description String?
  status      String      @default("ACTIVE")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plotPoints  PlotPoint[]
}

model PlotPoint {
  id          String   @id @default(uuid())
  plotId      String
  title       String
  type        String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plot        Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
}

model Chapter {
  id                String             @id @default(uuid())
  projectId         String
  title             String
  order             Int
  status            String             @default("DRAFT")
  wordCount         Int                @default(0)
  summary           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  webNovelTemplateId String?
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contents          ChapterContent[]
  summaries         ChapterSummary[]
  loreUsages        LoreUsage[]
  setupGuns         ChekhovsGun[]      @relation("SetupChapter")
  payoffGuns        ChekhovsGun[]      @relation("PayoffChapter")
  storyContracts    StoryContract[]
  storyContextPacks StoryContextPack[]
  storyAgentRuns    StoryAgentRun[]
  chapterCommits    ChapterCommit[]
  reviewReports     ReviewReport[]
  repairPlans       RepairPlan[]
  storyEvents       StoryEvent[]
  characterStates   CharacterState[]
  worldStateFacts   WorldStateFact[]
  entityMentions    EntityMention[]
  storyAiJobs       StoryAiJob[]
}

model StoryAiJob {
  id        String   @id @default(uuid())
  projectId String
  chapterId String
  type      String
  status    String   @default("PENDING")
  input     String
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model ProjectAiSuggestionJob {
  id        String   @id @default(uuid())
  projectId String
  status    String   @default("PENDING")
  input     String
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model ProjectStoryAiJob {
  id        String   @id @default(uuid())
  projectId String
  type      String
  status    String   @default("PENDING")
  input     String
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model OutlineAiJob {
  id        String   @id @default(uuid())
  projectId String
  status    String   @default("PENDING")
  input     String
  result    String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

model ChapterContent {
  id        String   @id @default(uuid())
  chapterId String
  content   String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ChapterSummary {
  id        String   @id @default(uuid())
  chapterId String
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ConsistencyCheckRule {
  id          String   @id @default(uuid())
  userId      String
  category    String
  name        String
  description String?
  isEnabled   Boolean  @default(true)
  severity    String   @default("NORMAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConsistencyCheckReport {
  id            String    @id @default(uuid())
  projectId     String
  chapterId     String?
  content       String
  reportData    String
  totalIssues   Int       @default(0)
  criticalCount Int       @default(0)
  normalCount   Int       @default(0)
  minorCount    Int       @default(0)
  isReviewed    Boolean   @default(false)
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
}

model CharacterAppearance {
  id          String    @id @default(uuid())
  characterId String
  chapterId   String?
  description String
  details     String?
  context     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([chapterId])
}

model ApiKey {
  id           String     @id @default(uuid())
  userId       String
  provider     String
  name         String
  encryptedKey String
  baseUrl      String? // 自定义 API 端点地址
  isActive     Boolean    @default(true)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs    UsageLog[]
  aiConfigs    AIConfig[]
}

model UsageLog {
  id               String   @id @default(uuid())
  apiKeyId         String
  endpoint         String
  method           String
  model            String?
  statusCode       Int?
  requestBody      String?
  responseBody     String?
  tokensUsed       Int?
  promptTokens     Int?
  completionTokens Int?
  cost             Float?
  duration         Int?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  apiKey           ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([model])
}

model LogRetentionSetting {
  id          String   @id @default(uuid())
  userId      String   @unique
  retentionDays Int    @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CustomWritingStyle {
  id          String                @id @default(uuid())
  userId      String
  name        String
  description String?
  icon        String?
  config      String
  sourceType  String
  sourceData  String?
  isPublic    Boolean               @default(false)
  useCount    Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  history     WritingStyleHistory[]

  @@index([userId])
}

model WritingStyleFusion {
  id                    String   @id @default(uuid())
  userId                String
  name                  String
  description           String?
  styles                String
  resultConfig          String
  compatibilityAnalysis String?
  createdAt             DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WritingStyleHistory {
  id        String              @id @default(uuid())
  userId    String
  projectId String?
  styleId   String?
  action    String
  details   String?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  style     CustomWritingStyle? @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([styleId])
}

// ==================== Lorebook/设定簿系统 ====================
model LoreEntry {
  id          String  @id @default(uuid())
  projectId   String
  name        String
  category    String // CHARACTER, LOCATION, ITEM, MAGIC, RACE, ORGANIZATION, OTHER
  description String
  content     String? // 详细内容，可以是Markdown
  keywords    String // 逗号分隔的触发关键词
  priority    Int     @default(50) // 优先级，越高越先匹配
  isActive    Boolean @default(true)
  order       Int     @default(0)

  // 条件触发
  triggerCondition    String? // 触发条件（可选）
  relatedCharacterIds String? // 关联角色ID（逗号分隔）
  relatedLocationIds  String? // 关联地点ID（逗号分隔）

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usages    LoreUsage[]

  @@index([projectId])
  @@index([projectId, category])
  @@index([projectId, isActive])
}

model LoreUsage {
  id          String    @id @default(uuid())
  loreEntryId String
  chapterId   String?
  content     String
  context     String?
  createdAt   DateTime  @default(now())
  loreEntry   LoreEntry @relation(fields: [loreEntryId], references: [id], onDelete: Cascade)
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([loreEntryId])
  @@index([chapterId])
}

// ==================== 伏笔/Chekhov's Gun系统 ====================
model ChekhovsGun {
  id             String  @id @default(uuid())
  projectId      String
  name           String
  description    String
  setupText      String // 埋设伏笔的原文
  setupChapterId String? // 埋设伏笔的章节
  setupPosition  Int? // 在章节中的位置

  // 状态
  status          String  @default("SETUP") // SETUP, REMINDER, PAYOFF, ABANDONED
  payoffText      String? // 回收伏笔的原文
  payoffChapterId String? // 回收伏笔的章节

  // 元数据
  importance String  @default("NORMAL") // MINOR, NORMAL, MAJOR, CRITICAL
  tags       String? // 逗号分隔的标签
  notes      String? // 作者备注

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  setupChapter  Chapter? @relation("SetupChapter", fields: [setupChapterId], references: [id], onDelete: Cascade)
  payoffChapter Chapter? @relation("PayoffChapter", fields: [payoffChapterId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, status])
  @@index([setupChapterId])
  @@index([payoffChapterId])
}

// ==================== 大纲系统 ====================
model Outline {
  id            String        @id @default(uuid())
  projectId     String
  title         String
  description   String?
  structureType String        @default("FULL_BOOK") // FULL_BOOK, VOLUME, ARC
  status        String        @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         OutlineItem[]

  @@index([projectId])
}

model OutlineItem {
  id             String        @id @default(uuid())
  outlineId      String
  chapterId      String?
  parentId       String?
  title          String
  summary        String?
  goal           String?
  conflict       String?
  outcome        String?
  povCharacter   String?
  location       String?
  estimatedWords Int?
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  outline        Outline       @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  parent         OutlineItem?  @relation("OutlineItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       OutlineItem[] @relation("OutlineItemTree")

  @@index([outlineId])
  @@index([parentId])
  @@index([chapterId])
}

// ==================== 转折点系统 ====================
model TurningPoint {
  id             String   @id @default(uuid())
  projectId      String
  chapterId      String?
  title          String
  type           String   @default("PLOT_TURN") // PLOT_TURN, CHARACTER_REVEAL, REVERSAL, CRISIS, CLIMAX, RESOLUTION
  description    String?
  impact         String?
  emotionalShift String?
  position       String? // 故事中的位置描述
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
}

// ==================== 时间线系统 ====================
model TimelineEvent {
  id          String   @id @default(uuid())
  projectId   String
  chapterId   String?
  title       String
  eventDate   String? // 故事内日期（可以是模糊的）
  timeLabel   String? // 时间标签，如"黎明"、"三天后"
  description String?
  location    String?
  characters  String? // 关联角色（逗号分隔）
  importance  String   @default("NORMAL") // MINOR, NORMAL, MAJOR, CRITICAL
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
}

// ==================== 角色对话沙盒 ====================
model DialogueSession {
  id                String                  @id @default(uuid())
  projectId         String
  chapterId         String?
  title             String
  location          String?
  conflict          String
  goal              String
  mood              String?
  allowSecretReveal Boolean                 @default(false)
  length            String                  @default("medium") // short, medium, long
  status            String                  @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  characterIds      String
  currentTurn       Int                     @default(0)
  lastInstruction   String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages          DialogueMessage[]
  qualityReports    DialogueQualityReport[]

  @@index([projectId])
  @@index([chapterId])
  @@index([status])
}

model DialogueMessage {
  id        String          @id @default(uuid())
  sessionId String
  speaker   String
  content   String
  type      String          @default("DIALOGUE") // DIALOGUE, INSTRUCTION, SYSTEM
  order     Int
  metadata  String?
  createdAt DateTime        @default(now())
  session   DialogueSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([order])
}

model DialogueQualityReport {
  id        String                 @id @default(uuid())
  projectId String
  sessionId String
  status    String                 @default("PASS") // PASS, WARN
  summary   String?
  createdAt DateTime               @default(now())
  project   Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session   DialogueSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  issues    DialogueQualityIssue[]

  @@index([projectId])
  @@index([sessionId])
  @@index([status])
}

model DialogueQualityIssue {
  id        String                @id @default(uuid())
  reportId  String
  category  String // OOC, VOICE_SIMILARITY, SECRET_LEAK, LOW_CONFLICT, FORMAT
  severity  String                @default("NORMAL") // CRITICAL, NORMAL, MINOR
  message   String
  speaker   String?
  evidence  String?
  createdAt DateTime              @default(now())
  report    DialogueQualityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([category])
  @@index([severity])
}

// ==================== Story System 合同/Agent/提交链 ====================
model StoryContract {
  id          String   @id @default(uuid())
  projectId   String
  chapterId   String?
  type        String // MASTER_SETTING, VOLUME_BRIEF, CHAPTER_BRIEF, REVIEW_CONTRACT
  version     String   @default("story-system/v1")
  status      String   @default("ACTIVE") // ACTIVE, SUPERSEDED
  payload     String
  sourceTrace String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([projectId, chapterId, type])
  @@index([projectId])
  @@index([chapterId])
  @@index([type])
}

model StoryContextPack {
  id                 String   @id @default(uuid())
  projectId          String
  chapterId          String?
  status             String   @default("READY") // READY, STALE, FAILED
  sections           String
  totalTokenEstimate Int      @default(0)
  warnings           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter            Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
  @@index([status])
}

model StoryAgentRun {
  id          String           @id @default(uuid())
  projectId   String
  chapterId   String?
  mode        String           @default("FULL_WRITE") // FULL_WRITE, REVIEW_ONLY, EXTRACT_ONLY
  status      String           @default("RUNNING") // RUNNING, PAUSED, COMPLETED, FAILED
  currentStep String           @default("CONTEXT")
  instruction String?
  metadata    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter?         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  steps       StoryAgentStep[]
  commits     ChapterCommit[]

  @@index([projectId])
  @@index([chapterId])
  @@index([status])
}

model StoryAgentStep {
  id        String        @id @default(uuid())
  runId     String
  stepType  String // CONTEXT, DRAFT, REVIEW, EXTRACT, COMMIT
  status    String        @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  input     String?
  output    String?
  error     String?
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  run       StoryAgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([stepType])
  @@index([status])
}

model ChapterCommit {
  id                String           @id @default(uuid())
  projectId         String
  chapterId         String
  runId             String?
  repairPlanId      String?
  status            String           @default("PENDING") // ACCEPTED, REJECTED, PENDING
  contentSnapshot   String
  blockingReasons   String?
  reviewResult      String
  fulfillmentResult String
  extractionResult  String
  acceptedEvents    String?
  stateDeltas       String?
  entityDeltas      String?
  summaryText       String?
  projectionStatus  String
  createdAt         DateTime         @default(now())
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter           Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  agentRun          StoryAgentRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  reviewReports     ReviewReport[]
  repairPlan        RepairPlan?
  storyEvents       StoryEvent[]
  characterStates   CharacterState[]
  worldStateFacts   WorldStateFact[]
  openLoops         OpenLoop[]
  entityMentions    EntityMention[]

  @@index([projectId])
  @@index([chapterId])
  @@index([runId])
  @@index([repairPlanId])
  @@index([status])
}

model ReviewReport {
  id          String         @id @default(uuid())
  projectId   String
  chapterId   String
  commitId    String?
  status      String         @default("PASS") // PASS, BLOCKED
  summary     String?
  createdAt   DateTime       @default(now())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter     Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  commit      ChapterCommit? @relation(fields: [commitId], references: [id], onDelete: Cascade)
  issues      ReviewIssue[]
  repairPlans RepairPlan[]

  @@index([projectId])
  @@index([chapterId])
  @@index([commitId])
  @@index([status])
}

model ReviewIssue {
  id          String       @id @default(uuid())
  reportId    String
  category    String // FULFILLMENT, CONTINUITY, CHARACTER, WORLD, PACING, READER_PULL, STYLE
  severity    String       @default("NORMAL") // CRITICAL, NORMAL, MINOR
  blocking    Boolean      @default(false)
  message     String
  evidence    String?
  suggestion  String?
  startOffset Int?
  endOffset   Int?
  createdAt   DateTime     @default(now())
  report      ReviewReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([category])
  @@index([blocking])
}

model RepairPlan {
  id           String         @id @default(uuid())
  projectId    String
  chapterId    String
  commitId     String?        @unique
  reportId     String?
  status       String         @default("OPEN") // OPEN, APPLIED, DISMISSED
  steps        String
  targetRanges String?
  overrideReason String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter      Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  commit       ChapterCommit? @relation(fields: [commitId], references: [id], onDelete: Cascade)
  report       ReviewReport?  @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([chapterId])
  @@index([reportId])
  @@index([status])
}

model StoryEvent {
  id        String        @id @default(uuid())
  projectId String
  chapterId String
  commitId  String
  eventType String
  subject   String
  payload   String?
  createdAt DateTime      @default(now())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter   Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  commit    ChapterCommit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
  @@index([commitId])
  @@index([eventType])
}

model CharacterState {
  id            String        @id @default(uuid())
  projectId     String
  chapterId     String
  commitId      String
  characterName String
  field         String
  value         String
  createdAt     DateTime      @default(now())
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter       Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  commit        ChapterCommit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
  @@index([commitId])
  @@index([characterName])
}

model WorldStateFact {
  id        String        @id @default(uuid())
  projectId String
  chapterId String
  commitId  String
  key       String
  category  String        @default("FACT") // RULE, LOCATION, ITEM, ORGANIZATION, FACT
  value     String
  source    String?
  createdAt DateTime      @default(now())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter   Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  commit    ChapterCommit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chapterId])
  @@index([commitId])
  @@index([key])
  @@index([category])
}

model OpenLoop {
  id        String         @id @default(uuid())
  projectId String
  chapterId String?
  commitId  String?
  key       String
  title     String
  status    String         @default("OPEN") // OPEN, RESOLVED
  payload   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commit    ChapterCommit? @relation(fields: [commitId], references: [id], onDelete: SetNull)

  @@unique([projectId, key])
  @@index([projectId])
  @@index([chapterId])
  @@index([commitId])
  @@index([status])
}

model StoryEntity {
  id            String          @id @default(uuid())
  projectId     String
  name          String
  type          String          @default("CONCEPT") // CHARACTER, LOCATION, ITEM, ORGANIZATION, CONCEPT, EVENT
  aliases       String?
  payload       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mentions      EntityMention[]
  relationsFrom StoryRelation[] @relation("StoryRelationFrom")
  relationsTo   StoryRelation[] @relation("StoryRelationTo")

  @@unique([projectId, name])
  @@index([projectId])
  @@index([type])
}

model EntityMention {
  id        String         @id @default(uuid())
  projectId String
  entityId  String
  chapterId String?
  commitId  String?
  excerpt   String?
  createdAt DateTime       @default(now())
  entity    StoryEntity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  chapter   Chapter?       @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  commit    ChapterCommit? @relation(fields: [commitId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([entityId])
  @@index([chapterId])
  @@index([commitId])
}

model StoryRelation {
  id           String      @id @default(uuid())
  projectId    String
  fromEntityId String
  toEntityId   String
  type         String
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromEntity   StoryEntity @relation("StoryRelationFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity     StoryEntity @relation("StoryRelationTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromEntityId, toEntityId, type])
  @@index([projectId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([type])
}

model Conversation {
  id        String   @id @default(uuid())
  projectId String
  title     String
  type      String   @default("general")
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  role           String
  content        String
  timestamp      DateTime      @default(now())
  actionsJson    String?
  cardsJson      String?
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
